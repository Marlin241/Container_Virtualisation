# Copiez ce fichier vers .env et personnalisez les valeurs avant un déploiement
# réel. .env est ignoré par git (voir .gitignore) — ne committez jamais de
# vrais secrets. Si aucun .env n'est présent, docker-compose.yml utilise les
# valeurs par défaut ci-dessous (suffisant pour un usage local/démo).

# Identifiants PostgreSQL partagés par les 3 bases (users-db, books-db, loans-db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Secret utilisé pour signer/valider les JWT, partagé par les 3 microservices
JWT_SECRET=devsecret

# Compte PERSONNEL_ADMIN créé automatiquement au premier démarrage de
# users-service (uniquement si aucun compte admin n'existe déjà en base).
# L'inscription publique (/auth/register) refuse le rôle PERSONNEL_ADMIN —
# c'est le seul moyen d'obtenir un premier compte admin. Les admins suivants
# sont créés en promouvant un utilisateur existant (page Utilisateurs, en
# étant déjà connecté en tant qu'admin).
ADMIN_EMAIL=admin@dit.sn
ADMIN_PASSWORD=admin123

# GID du groupe "docker" sur la machine hôte, nécessaire pour que le
# conteneur jenkins puisse utiliser le socket Docker monté. Obtenez la valeur
# avec "getent group docker" et ajustez si elle diffère de 989.
DOCKER_GID=989

# Identifiants du compte administrateur Jenkins, injectés via Jenkins
# Configuration as Code (jenkins/casc.yaml). L'assistant d'installation
# interactif est désactivé — Jenkins démarre directement avec ce compte,
# aucune étape manuelle via navigateur n'est nécessaire pour la connexion.
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=adminpass123

# URL du dépôt Git utilisée par Jenkins Configuration as Code pour créer
# automatiquement le job Pipeline "bibliotheque-microservices" au démarrage
# (voir jobs: dans jenkins/casc.yaml). Utilisez l'URL HTTPS (pas SSH) : le
# clonage se fait depuis l'intérieur du conteneur jenkins, sans clé SSH
# configurée — ne fonctionne que pour un dépôt public.
REPO_URL=https://github.com/Marlin241/Container_Virtualisation.git
